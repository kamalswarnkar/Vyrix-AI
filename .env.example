# ──────────────────────────────────────────────────────────────
# Vyrix AI — environment variables
# Copy this file to .env.local for local development, or pass
# these as environment variables in your Docker Compose override.
# ──────────────────────────────────────────────────────────────

# ── Ollama ─────────────────────────────────────────────────
# Base URL of the local Ollama server.
# Docker stack: http://ollama:11434 (service name)
# Local dev:    http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Chat model — must match a model pulled in Ollama.
# "vyrix-research" is the tuned model created from ollama/Modelfile.
# Fallback plain options: llama3.1:8b-instruct, llama3:8b-instruct
DEFAULT_CHAT_MODEL=vyrix-research

# Embedding model — kept separate from the chat model.
# nomic-embed-text is fast, lightweight, and produces 768-dim vectors.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Storage ────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
VYRIX_SQLITE_PATH=./data/vyrix.sqlite

# Directory where uploaded documents are stored on disk.
VYRIX_UPLOAD_STORAGE_ROOT=./data/uploads

# ── Chat behaviour ─────────────────────────────────────────
# Maximum number of previous messages included in each prompt.
AI_CHAT_HISTORY_LIMIT=20

# ── Timeouts (milliseconds) ────────────────────────────────
# How long to wait for a normal LLM response.
AI_REQUEST_TIMEOUT_MS=180000

# How long to wait for the Ollama health-check ping.
AI_HEALTH_TIMEOUT_MS=5000

# ── Docker host port mappings (docker-compose.yml only) ────
# Change these if the default ports clash on your machine.
OLLAMA_HOST_PORT=11434
CHROMA_HOST_PORT=8000
VYRIX_HOST_PORT=3000

# ── ChromaDB (future / optional) ───────────────────────────
# Uncomment when switching from sqlite-faiss to ChromaDB.
# CHROMA_BASE_URL=http://localhost:8000
